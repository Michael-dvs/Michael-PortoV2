// This is your Prisma schema file for the Michael Aristyo Portfolio.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7+: connection URLs are now configured in prisma.config.ts
  // See: https://pris.ly/d/config-datasource
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Model: Project
// Maps to the `projects` table in PostgreSQL.
// ─────────────────────────────────────────────────────────────
model Project {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  thumbnailUrl String   @map("thumbnail_url")
  liveUrl      String?  @map("live_url")
  repoUrl      String?  @map("repo_url")
  techStack    String[] @map("tech_stack")
  isFeatured   Boolean  @default(false) @map("is_featured")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isFeatured])
  @@index([createdAt(sort: Desc)])
  @@map("projects")
}

// ─────────────────────────────────────────────────────────────
// Model: LabActivity
// Maps to the `lab_activities` table in PostgreSQL.
// ─────────────────────────────────────────────────────────────
model LabActivity {
  id          String   @id @default(cuid())
  role        String
  imageUrl    String   @map("image_url")
  description String
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([sortOrder(sort: Asc)])
  @@map("lab_activities")
}
